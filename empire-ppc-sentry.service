[Unit]
Description=Empire OS agent: sentry (self-heal watchdog)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/root/empire_os
EnvironmentFile=/root/empire_os/.env
ExecStart=/root/empire_os/venv/bin/python3 /root/empire_os/empire_os/agents/sentry_agent.py
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
