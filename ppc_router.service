[Unit]
Description=Empire OS agent: ppc_router (5-headed billing brain)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/root/empire_os
EnvironmentFile=/root/empire_os/.env
ExecStart=/root/empire_os/venv/bin/python3 /root/empire_os/empire_os/ppc_router.py
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
